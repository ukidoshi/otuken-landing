VITE_SITE_URL=https://otuken.ru
VITE_DISTRICT_INTEREST_ENDPOINT=/api/leads/district-interest
# Laravel API. В production — полный URL (https://api.site.ru).
# В dev можно не задавать: запросы идут на /api через прокси Vite → localhost:8081 (см. vite.config.js).
VITE_API_URL=
VITE_API_BASE_URL=
VITE_NEWS_PREVIEW_PATH=/news-preview

# Google Analytics 4 measurement ID, for example G-XXXXXXXXXX
VITE_GA_MEASUREMENT_ID=

# Yandex Metrika counter ID
VITE_YANDEX_METRIKA_ID=

# Google Search Console verification token
VITE_GOOGLE_SITE_VERIFICATION=

# Yandex Webmaster verification token
VITE_YANDEX_VERIFICATION=
